/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=()

  # Tightened CSP for Traffic Torch (removes broad https: + reduces warnings)
  Content-Security-Policy: default-src 'self' https:;
    script-src 'self' 'unsafe-inline' 'unsafe-eval' 
      https://static.addtoany.com 
      https://cdn.jsdelivr.net 
      https://static.cloudflareinsights.com 
      https://www.googletagmanager.com 
      https://traffic-torch-api.traffictorch.workers.dev;
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
    font-src 'self' https://fonts.gstatic.com;
    img-src 'self' data: https: blob:;
    connect-src 'self' 
      https://traffic-torch-api.traffictorch.workers.dev 
      https://*.google-analytics.com 
      https://*.googletagmanager.com 
      https://static.addtoany.com;
    frame-src 'self' https://static.addtoany.com;
    frame-ancestors 'none';
    base-uri 'self';
    form-action 'self';
    upgrade-insecure-requests;